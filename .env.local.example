NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to true only when you want /test available on a deployment.
NEXT_PUBLIC_ENABLE_TEST_PAGE=false

# Only add this later if you move privileged work into server-only routes.
# Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only password for /admin/[password].
ADMIN_URL_PASSWORD=
